{
  "manifest_version": 3,
  "name": "Reel",
  "version": "1.0.0",
  "description": "Your universal entertainment tracker — movies, series, anime, manga, manhwa all in one place.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.disneyplus.com/*",
    "https://cinemaos.live/*",
    "https://www.crunchyroll.com/*",
    "https://www.funimation.com/*",
    "https://www.hidive.com/*",
    "https://mangadex.org/*",
    "https://www.webtoons.com/*",
    "https://tapas.io/*",
    "https://nepu.to/*",
    "https://aniwave.to/*",
    "https://*.9anime.to/*",
    "https://api.themoviedb.org/*",
    "https://graphql.anilist.co/*",
    "https://api.mangadex.org/*",
    "https://api.jikan.moe/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["content-scripts/netflix.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.disneyplus.com/*"],
      "js": ["content-scripts/disneyplus.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://cinemaos.live/*"],
      "js": ["content-scripts/cinemaos.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.crunchyroll.com/*"],
      "js": ["content-scripts/crunchyroll.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mangadex.org/*"],
      "js": ["content-scripts/mangadex.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.webtoons.com/*"],
      "js": ["content-scripts/webtoon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://www.netflix.com/*",
        "https://www.disneyplus.com/*",
        "https://cinemaos.live/*",
        "https://www.crunchyroll.com/*",
        "https://mangadex.org/*",
        "https://www.webtoons.com/*"
      ],
      "js": ["content-scripts/universal.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
