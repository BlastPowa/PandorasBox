# Supabase (Auth + Postgres + Realtime) — required for accounts, lists, admin
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, used by cron/admin refresh routes (service role — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# TMDB — required for movies/series discovery + watch providers (free key: themoviedb.org/settings/api)
# AniList, MangaDex and Jikan need no key.
TMDB_API_KEY=

# Protects the scheduled availability-refresh endpoint (any random string)
CRON_SECRET=

# Optional — Rotten Tomatoes / IMDb / Metacritic ratings on detail pages
# Free key (1000 req/day): omdbapi.com/apikey.aspx. If unset, those badges are simply hidden.
OMDB_API_KEY=

# Public site URL (used for auth redirects); localhost in dev, your domain in prod
NEXT_PUBLIC_SITE_URL=

# Optional Web Push (generate once with `npm run generate:vapid`, then set all
# three values in Vercel; never expose the private key to the browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional GIF and sticker search in Messages (uploads and built-in stickers work without it)
NEXT_PUBLIC_GIPHY_API_KEY=

# Optional — lets the FAQ "contact admin" form email you (free: 100/day at resend.com).
# Without these, submitted issues are still saved and visible in the Admin panel.
RESEND_API_KEY=
CONTACT_EMAIL=
